@model List<ProductWeb.Models.Product>

@{
    ViewData["Title"] = "Daftar Produk";
}

<!-- ── Page Header ─────────────────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="h3 fw-bold text-white mb-1">
            <i class="bi bi-grid me-2 text-warning"></i>Daftar Produk
        </h1>
        <p class="text-white-50 small mb-0">
            Total <strong class="text-warning">@Model.Count</strong> produk ditemukan
        </p>
    </div>
    @if (Context.Session.GetString("Role") == "Admin")
    {
        <a asp-action="Create" class="btn btn-warning fw-semibold">
            <i class="bi bi-plus-circle me-2"></i>Tambah Produk
        </a>
    }
</div>

<!-- ── Search & Filter ─────────────────────────────────────────────────────── -->
<div class="card mb-4 border-0 glass-card">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label text-white-50 small fw-semibold mb-1">CARI PRODUK</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary">
                        <i class="bi bi-search text-white-50"></i>
                    </span>
                    <input type="text" name="search" class="form-control form-control-dark"
                        placeholder="Nama, deskripsi, atau kategori..." id="searchInput" value="@ViewBag.Search" />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-white-50 small fw-semibold mb-1">KATEGORI</label>
                <select name="category" class="form-select form-select-dark" id="categorySelect">
                    <option value="">Semua Kategori</option>
                    @foreach (var cat in (ViewBag.Categories as List<string> ?? new List<string>()))
                    {
                        <option value="@cat" selected="@(ViewBag.Category == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-warning flex-fill">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- ── Product Table ────────────────────────────────────────────────────────── -->
@if (!Model.Any())
{
    <div class="text-center py-5">
    <i class="bi bi-box text-white-50 display-1 mb-3 d-block"></i>
    <h5 class="text-white-50">Tidak ada produk ditemukan</h5>
    <p class="text-white-50 small">Coba ubah filter pencarian atau tambah produk baru</p>
    @if (Context.Session.GetString("Role") == "Admin")
        {
            <a asp-action="Create" class="btn btn-warning mt-2">
                <i class="bi bi-plus-circle me-2"></i>Tambah Produk Pertama
            </a>
        }
    </div>
}
else
{
    <div class="card border-0 glass-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle" id="productTable">
                <thead>
                    <tr class="table-header-row">
                        <th class="ps-4 py-3">#</th>
                        <th>Nama Produk</th>
                        <th>Kategori</th>
                        <th>Harga</th>
                        <th>Stok</th>
                        <th class="text-center">Status</th>
                        <th class="text-center pe-4">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                        {
                            <tr class="product-row">
                                <td class="ps-4 text-white-50 small">@item.Id</td>
                                <td>
                                    <div class="fw-semibold text-white">@item.Name</div>
                                    <div class="text-white-50 small text-truncate" style="max-width: 220px;"
                                        title="@item.Description">
                                        @item.Description
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-category">@item.Category</span>
                                </td>
                                <td class="text-warning fw-semibold">
                                    Rp @item.Price.ToString("N0")
                                </td>
                                <td>
                                    <span class="text-white">@item.Stock</span>
                                    <span class="text-white-50 small">unit</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Stock > 10)
                                    {
                                        <span class="badge bg-success-subtle text-success">Tersedia</span>
                                    }
                                    else if (item.Stock > 0)
                                    {
                                        <span class="badge bg-warning-subtle text-warning">Stok Rendah</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Habis</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-outline-light btn-sm"
                                            title="Detail">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (Context.Session.GetString("Role") == "Admin")
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm"
                                                title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger btn-sm"
                                                onclick="confirmDelete(@item.Id, '@Html.Raw(item.Name.Replace("'", "\\'"))')"
                                                title="Hapus">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <!-- Pagination Footer -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer border-0 border-top border-secondary bg-transparent py-3">
                <nav aria-label="Product pagination">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <!-- Prev -->
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link bg-dark border-secondary text-white-50" asp-action="Index"
                                asp-route-search="@ViewBag.Search" asp-route-category="@ViewBag.Category"
                                asp-route-page="@(ViewBag.CurrentPage - 1)">
                                Previous
                            </a>
                        </li>

                        <!-- Pages -->
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link @(i == ViewBag.CurrentPage ? "bg-warning text-dark border-warning fw-bold" : "bg-dark border-secondary text-white")"
                                    asp-action="Index" asp-route-search="@ViewBag.Search" asp-route-category="@ViewBag.Category"
                                    asp-route-page="@i">
                                    @i
                                </a>
                            </li>
                        }

                        <!-- Next -->
                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link bg-dark border-secondary text-white-50" asp-action="Index"
                                asp-route-search="@ViewBag.Search" asp-route-category="@ViewBag.Category"
                                asp-route-page="@(ViewBag.CurrentPage + 1)">
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
}

<!-- ── Hidden Delete Form ──────────────────────────────────────────────────── -->
<form id="deleteForm" asp-action="Delete" asp-controller="Product" method="post" class="d-none">
    <input type="hidden" id="deleteId" name="id" />
</form>

<!-- ── Delete Confirmation Modal ──────────────────────────────────────────── -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-white">
                    <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Konfirmasi Hapus
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-white-50">
                Apakah Anda yakin ingin menghapus produk
                <strong class="text-white" id="deleteName"></strong>?
                <br /><span class="small text-danger">Tindakan ini tidak bisa dibatalkan.</span>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete">
                    <i class="bi bi-trash me-2"></i>Ya, Hapus
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

        function confirmDelete(id, name) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteName').textContent = name;
            deleteModal.show();
        }

        document.getElementById('btnConfirmDelete').addEventListener('click', function () {
            document.getElementById('deleteForm').action = '/Product/Delete/' + document.getElementById('deleteId').value;
            document.getElementById('deleteForm').submit();
        });
    </script>
}
